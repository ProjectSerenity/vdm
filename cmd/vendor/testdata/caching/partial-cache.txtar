-- deps.vdm --
go-modules:
	module "example.com/bar" v1.2.3
		packages:
			package "example.com/bar"
			package "example.com/bar/baz"
	module "golang.org/x/crypto" v1.2.3
		packages:
			package "golang.org/x/crypto"
	module "golang.org/x/mod" v1.2.3
		packages:
			package "golang.org/x/mod/module"
			package "golang.org/x/mod/zip"
	module "rsc.io/diff" v1.2.3
		packages:
			package "rsc.io/diff"
	module "rsc.io/quote" v1.5.2
		patches:
			"patches/quote.patch"
		packages:
			package "rsc.io/quote"
	module "rsc.io/tmp" v0.0.0-20260706223531-5a501281bc9f
		patches:
			"patches/foo.patch"
		packages:
			package "rsc.io/tmp/patch"

-- patches/quote.patch --
diff a/quote.go b/quote.go

